# ============================================================================
# AthleteOS — EditorConfig
# ============================================================================
# https://editorconfig.org
#
# Convenciones de edición que todos los editores modernos respetan.
# Esto mantiene consistencia sin depender de configs por-editor.
# ============================================================================

root = true

# ----------------------------------------------------------------------------
# Defaults para todos los archivos
# ----------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ----------------------------------------------------------------------------
# Archivos específicos
# ----------------------------------------------------------------------------

# Código C# — 4 espacios (estándar .NET)
[*.cs]
indent_size = 4
charset = utf-8-bom

# Archivos de proyecto .NET
[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj}]
indent_size = 2

# Soluciones y config de .NET
[*.{sln,props,targets}]
indent_style = tab

# Config de NuGet
[*.{config,nuspec}]
indent_size = 2

# TypeScript, JavaScript, JSON, YAML, HTML, CSS — 2 espacios (estándar JS)
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,html,css,scss,sass,less,vue,svelte}]
indent_size = 2

# Markdown — no trim trailing whitespace (porque dos espacios al final = <br>)
[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2

# Dockerfile
[{Dockerfile,Dockerfile.*,*.Dockerfile}]
indent_size = 2

# Docker Compose
[{docker-compose,docker-compose.*}.{yml,yaml}]
indent_size = 2

# SQL
[*.sql]
indent_size = 4

# Makefile — tabs obligatorios, no tocar
[{Makefile,makefile,*.mk}]
indent_style = tab

# ----------------------------------------------------------------------------
# Reglas específicas para C# — complementa .editorconfig del .NET SDK
# ----------------------------------------------------------------------------

[*.cs]

# === Organización de namespaces y usings ===
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# === File-scoped namespaces (C# 10+) ===
csharp_style_namespace_declarations = file_scoped:warning

# === var vs tipo explícito ===
# Preferimos var cuando el tipo es evidente de la derecha, tipo explícito cuando no.
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# === Expression-bodied members ===
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# === Null checks ===
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# === Pattern matching ===
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# === Modifiers ===
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

# === Naming conventions ===
# Interfaces con prefijo I
dotnet_naming_rule.interface_should_begin_with_i.severity = warning
dotnet_naming_rule.interface_should_begin_with_i.symbols = interface_symbol
dotnet_naming_rule.interface_should_begin_with_i.style = begins_with_i_style

dotnet_naming_symbols.interface_symbol.applicable_kinds = interface
dotnet_naming_style.begins_with_i_style.required_prefix = I
dotnet_naming_style.begins_with_i_style.capitalization = pascal_case

# Campos privados con _camelCase
dotnet_naming_rule.private_fields_should_have_underscore.severity = warning
dotnet_naming_rule.private_fields_should_have_underscore.symbols = private_field_symbol
dotnet_naming_rule.private_fields_should_have_underscore.style = underscore_camel_case_style

dotnet_naming_symbols.private_field_symbol.applicable_kinds = field
dotnet_naming_symbols.private_field_symbol.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case_style.required_prefix = _
dotnet_naming_style.underscore_camel_case_style.capitalization = camel_case

# Constantes en PascalCase (no SCREAMING_SNAKE_CASE)
dotnet_naming_rule.constants_should_be_pascal_case.severity = warning
dotnet_naming_rule.constants_should_be_pascal_case.symbols = constant_symbol
dotnet_naming_rule.constants_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.constant_symbol.applicable_kinds = field
dotnet_naming_symbols.constant_symbol.required_modifiers = const
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# === Diagnostics como errors (bloqueantes en build) ===
# Nullable warnings tratados como errors → previene NullReferenceException en runtime.
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8601.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8603.severity = error
dotnet_diagnostic.CS8604.severity = error

# Async methods que no usan await → sospechoso, warning.
dotnet_diagnostic.CS1998.severity = warning
