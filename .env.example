# ============================================================================
# AthleteOS — Environment variables (example / template)
# ============================================================================
#
# Copiá este archivo como `.env` y editá los valores según tu entorno local.
# NUNCA commitees `.env` (está en .gitignore).
# En producción, estas variables vienen del vault de secretos del proveedor
# (Railway / Fly.io / AWS Secrets Manager / Doppler).
#
# Cada variable tiene un comentario arriba explicando qué es y cuándo cambiarla.
# ============================================================================


# ----------------------------------------------------------------------------
# Ambiente
# ----------------------------------------------------------------------------

# Nombre del ambiente actual. Valores: Development | Staging | Production.
# Afecta logging, nivel de errores mostrados, etc.
ASPNETCORE_ENVIRONMENT=Development

# Puerto en el que la API escucha localmente.
API_PORT=5000


# ----------------------------------------------------------------------------
# PostgreSQL (OLTP principal + TimescaleDB)
# ----------------------------------------------------------------------------

# Host de PostgreSQL. Para dev local con Docker Compose: `localhost`.
POSTGRES_HOST=localhost

# Puerto. Default estándar.
POSTGRES_PORT=5432

# Base de datos principal.
POSTGRES_DB=athleteos

# Usuario. Cambiar en producción.
POSTGRES_USER=athleteos

# Password. Para dev local usamos una débil; en prod viene de vault.
POSTGRES_PASSWORD=devpassword

# Connection string completo (derivable de las de arriba, pero la app lo usa directo).
# El parámetro `Include Error Detail` es útil en dev, quitar en prod.
ConnectionStrings__Default=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Include Error Detail=true


# ----------------------------------------------------------------------------
# Redis (cache + event bus MVP)
# ----------------------------------------------------------------------------

# Host y puerto. Localhost en dev con Docker Compose.
REDIS_HOST=localhost
REDIS_PORT=6379

# Connection string que usa StackExchange.Redis.
ConnectionStrings__Redis=${REDIS_HOST}:${REDIS_PORT}


# ----------------------------------------------------------------------------
# Autenticación y seguridad
# ----------------------------------------------------------------------------

# Secret para firmar JWTs. En dev podés usar uno largo random.
# EN PRODUCCIÓN: generar con `openssl rand -base64 64` y guardar en vault.
# NUNCA reusar el mismo secret entre ambientes.
JWT_SIGNING_KEY=change-me-in-production-with-at-least-64-random-bytes

# Emisor de los JWTs (tu dominio).
JWT_ISSUER=https://athleteos.local

# Audience esperada en los JWTs.
JWT_AUDIENCE=athleteos-api

# Tiempo de vida del access token (en minutos).
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15

# Tiempo de vida del refresh token (en días).
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Key para cifrado a nivel aplicación de campos sensibles (tokens OAuth,
# datos médicos). Generar con `openssl rand -base64 32`.
# Rotación: cada 90 días en prod.
DATA_PROTECTION_KEY=change-me-32-random-bytes-base64-encoded


# ----------------------------------------------------------------------------
# Proveedores externos — Wearables
# ----------------------------------------------------------------------------

# Strava OAuth. Registrá una app en https://www.strava.com/settings/api
# y pegá los valores acá. Para dev podés usar una app de desarrollo separada.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:5000/oauth/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Garmin Connect IQ (cuando se implemente integración oficial).
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Polar AccessLink (cuando se implemente).
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=


# ----------------------------------------------------------------------------
# LLM — Anthropic
# ----------------------------------------------------------------------------

# API Key de Anthropic. Obtener en https://console.anthropic.com
# Para dev es razonable tener una key separada con límite de gasto configurado.
ANTHROPIC_API_KEY=

# Modelo default para generación de sugerencias. Otros modelos se usan por tarea.
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6

# Modelo para tareas simples (clasificación, respuestas cortas).
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# Límite de gasto diario en USD (soft limit). La app loguea warning al superarlo.
LLM_DAILY_BUDGET_USD=10


# ----------------------------------------------------------------------------
# Email transaccional
# ----------------------------------------------------------------------------

# En dev usamos MailHog corriendo en Docker Compose (puerto SMTP 1025, UI en 8025).
# En prod: Resend, SendGrid, o similar.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@athleteos.local
SMTP_FROM_NAME=AthleteOS


# ----------------------------------------------------------------------------
# Object storage (FIT files, exports, assets)
# ----------------------------------------------------------------------------

# En prod: Cloudflare R2 o AWS S3.
# En dev: podés dejar vacío y usar almacenamiento de archivos en disco local,
# o levantar MinIO via Docker Compose (opcional, no incluido por defecto).
STORAGE_PROVIDER=LocalDisk
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=athleteos-dev
STORAGE_REGION=auto
# Directorio local si STORAGE_PROVIDER=LocalDisk
STORAGE_LOCAL_PATH=./.docker-data/storage


# ----------------------------------------------------------------------------
# Observabilidad
# ----------------------------------------------------------------------------

# Sentry DSN. Para dev podés dejar vacío (logueo solo a consola).
SENTRY_DSN=

# OpenTelemetry endpoint (OTLP).
# Para dev podés dejar vacío o apuntar a un collector local.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=athleteos-api

# Nivel mínimo de log que sale por Serilog. Valores: Verbose, Debug, Information, Warning, Error, Fatal.
LOG_LEVEL=Debug


# ----------------------------------------------------------------------------
# Feature flags (para features en desarrollo)
# ----------------------------------------------------------------------------

# Habilita el módulo de billing (Fase 2).
FEATURE_BILLING_ENABLED=false

# Habilita integración con Garmin (cuando esté lista).
FEATURE_GARMIN_ENABLED=false

# Habilita learning loop de Intelligence (aprendizaje del estilo del coach).
FEATURE_COACH_STYLE_LEARNING=false


# ----------------------------------------------------------------------------
# Frontend (cuando se agregue — Bloque 4)
# ----------------------------------------------------------------------------

# URL base de la API que usan los frontends.
VITE_API_BASE_URL=http://localhost:5000

# Entorno del frontend.
VITE_APP_ENV=development
